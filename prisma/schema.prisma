  actionType    String
  oldValueJson  Json?
  newValueJson  Json?
  metaJson      Json?

  user          User?     @relation(fields: [userId], references: [id])

  @@index([txId])
  @@index([occurredAt])
  @@index([module, entity, entityId])
}

model DomainEvent {
  id           String    @id @default(cuid())
  txId         String
  eventType    String
  payloadJson  Json
  createdAt    DateTime  @default(now())
  publishedAt  DateTime?

  @@index([txId])
  @@index([eventType])
  @@index([publishedAt])
}





