}

model DiscrepancyCase {
  id                 String   @id @default(cuid())
  reconciliationId   String
  lineId             String?
  caseType           String
  severity           String   @default("medium")
  status             String   @default("open")
  title              String
  description        String?
  expectedAmount     Decimal? @db.Decimal(14, 2)
  actualAmount       Decimal? @db.Decimal(14, 2)
  sourceModule       String?
  sourceEntity       String?
  sourceEntityId     String?
  financeEntryId     String?
  resolutionNotes    String?
  resolvedByUserId   String?
  resolvedByName     String?
  resolvedAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  reconciliation     FinanceReconciliation @relation(fields: [reconciliationId], references: [id])
  line               ReconciliationLine?   @relation(fields: [lineId], references: [id])

  @@index([reconciliationId, status])
  @@index([caseType])
}

