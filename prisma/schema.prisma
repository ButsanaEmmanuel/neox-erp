  nextRunAt            DateTime?
  lastRunAt            DateTime?
  lastRunStatus        String?
  createdByUserId      String?
  createdByName        String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  runs                 PayrollRun[]
  history              PayrollScheduleHistory[]

  @@index([isActive, nextRunAt])
}

model PayrollScheduleHistory {
  id                   String   @id @default(cuid())
  payrollScheduleId    String
  changedByUserId      String?
  changedByName        String?
  changeType           String
  oldValueJson         Json?
  newValueJson         Json?
  createdAt            DateTime @default(now())

  payrollSchedule      PayrollSchedule @relation(fields: [payrollScheduleId], references: [id])

  @@index([payrollScheduleId, createdAt])
}

model PayrollPeriod {
  id                   String   @id @default(cuid())
  code                 String   @unique
  periodStart          DateTime
  periodEnd            DateTime
  month                Int
  year                 Int
  createdAt            DateTime @default(now())

  runs                 PayrollRun[]

  @@index([year, month])
}

model PayrollRun {
  id                   String   @id @default(cuid())
  runCode              String   @unique
  payrollScheduleId    String?
  payrollPeriodId      String
  payrollBatchId       String?
  triggerType          String   @default("manual")
  startedAt            DateTime @default(now())
  completedAt          DateTime?
  postingCompletedAt   DateTime?
  status               String   @default("running")
  validationMode       String   @default("review_before_posting")
  postingStatus        String   @default("pending_validation")
  warningCount         Int      @default(0)
  errorCount           Int      @default(0)
  totalEmployees       Int      @default(0)
  includedEmployees    Int      @default(0)
  excludedEmployees    Int      @default(0)
  blockedEmployees     Int      @default(0)
  totalRegularPay      Decimal  @default(0) @db.Decimal(14, 2)
  totalOvertimePay     Decimal  @default(0) @db.Decimal(14, 2)
  totalGrossPay        Decimal  @default(0) @db.Decimal(14, 2)
  currencyCode         String   @default("USD")
  startedByUserId      String?
  startedByName        String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  payrollSchedule      PayrollSchedule? @relation(fields: [payrollScheduleId], references: [id])
  payrollPeriod        PayrollPeriod @relation(fields: [payrollPeriodId], references: [id])
  payrollBatch         PayrollBatch? @relation(fields: [payrollBatchId], references: [id])
  employees            PayrollRunEmployee[]
  notifications        PayrollNotification[]
  logs                 PayrollRunLog[]

  @@index([payrollScheduleId, startedAt])
  @@index([payrollPeriodId])
  @@index([status, postingStatus])
}

model PayrollRunEmployee {
  id                   String   @id @default(cuid())
  payrollRunId         String
  userId               String
  departmentId         String?
  salaryProfileId      String?
  inclusionStatus      String   @default("included")
  exclusionReason      String?
  regularWorkedDays    Decimal  @default(0) @db.Decimal(8, 2)
  weekendWorkedDays    Decimal  @default(0) @db.Decimal(8, 2)
  standardWorkingDays  Int      @default(0)
  dailyRate            Decimal  @default(0) @db.Decimal(14, 4)
  overtimeMultiplier   Decimal  @default(1.50) @db.Decimal(6, 2)
  regularPay           Decimal  @default(0) @db.Decimal(14, 2)
  overtimePay          Decimal  @default(0) @db.Decimal(14, 2)
  grossPay             Decimal  @default(0) @db.Decimal(14, 2)
  adjustedGrossPay     Decimal? @db.Decimal(14, 2)
  payrollLineId        String?
  payableId            String?
  warningJson          Json?
  errorJson            Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  payrollRun           PayrollRun @relation(fields: [payrollRunId], references: [id])

  @@unique([payrollRunId, userId])
  @@index([payrollRunId, inclusionStatus])
  @@index([payableId])
}

model PayrollRunTimesheetLink {
