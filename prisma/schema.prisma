model FinanceReconciliation {
  id                 String   @id @default(cuid())
  reconciliationCode String   @unique
  periodStart        DateTime?
  periodEnd          DateTime?
  status             String   @default("completed")
  runByUserId        String?
  runByName          String?
  summaryJson        Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  closedAt           DateTime?

  lines              ReconciliationLine[]
  discrepancyCases   DiscrepancyCase[]

  @@index([status])
  @@index([createdAt])
}

model ReconciliationLine {
  id                 String   @id @default(cuid())
  reconciliationId   String
  movementType       String
  movementId         String
  referenceCode      String?
  sourceModule       String?
  sourceEntity       String?
  sourceEntityId     String?
  financeEntryId     String?
  expectedAmount     Decimal? @db.Decimal(14, 2)
  actualAmount       Decimal? @db.Decimal(14, 2)
  proofPresent       Boolean  @default(false)
