  userId        String
  departmentId  String
  workDate      DateTime
  hours         Decimal     @db.Decimal(5, 2)
  description   String?
  statusCode    String      @default("submitted")
  isDeleted     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  user          User        @relation(fields: [userId], references: [id])
  department    Department  @relation(fields: [departmentId], references: [id])

  @@index([userId, workDate])
  @@index([departmentId])
  @@index([isDeleted])
}

model PurchaseRequest {
  id                     String      @id @default(cuid())
  requestNumber          String      @unique
  requesterUserId        String
  requesterDepartmentId  String
  statusCode             String      @default("draft")
  justification          String?
  totalAmount            Decimal?    @db.Decimal(14, 2)
  isDeleted              Boolean     @default(false)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  deletedAt              DateTime?

  requester              User        @relation("Requester", fields: [requesterUserId], references: [id])
  requesterDepartment    Department  @relation(fields: [requesterDepartmentId], references: [id])

  @@index([requesterUserId])
  @@index([requesterDepartmentId])
  @@index([isDeleted])
}

model RecruitmentCandidate {
  id                      String      @id @default(cuid())
  fullName                String
  personalEmail           String
  phone                   String?
  position                String
  statusCode              String      @default("sourced")
  recruitmentDepartmentId String
  hiredUserId             String?     @unique
  hiredAt                 DateTime?
  isDeleted               Boolean     @default(false)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  deletedAt               DateTime?

  recruitmentDepartment   Department  @relation(fields: [recruitmentDepartmentId], references: [id])
  hiredUser               User?       @relation("CandidateHiredUser", fields: [hiredUserId], references: [id])
  accessProvisionings     AccessProvisioning[]

  @@index([statusCode])
  @@index([recruitmentDepartmentId])
  @@index([isDeleted])
}

model AccessProvisioning {
  id                       String      @id @default(cuid())
  candidateId              String
  userId                   String
  statusCode               String      @default("provisioned")
  temporaryPasswordSentAt  DateTime?
  forcedPasswordChangedAt  DateTime?
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  candidate                RecruitmentCandidate @relation(fields: [candidateId], references: [id])
  user                     User                 @relation(fields: [userId], references: [id])

  @@unique([candidateId, userId])
  @@index([statusCode])
}

model AuditLog {
